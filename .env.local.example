# =============================================================================
# ENVIRONMENT VARIABLES — SETUP GUIDE
# =============================================================================
# Copy this file to .env.local and fill in your own values.
# NEVER commit .env.local to version control.
#
# SUPABASE (https://supabase.com)
#   - Create a project at supabase.com/dashboard
#   - NEXT_PUBLIC_SUPABASE_URL: Settings → API → Project URL
#   - NEXT_PUBLIC_SUPABASE_ANON_KEY: Settings → API → anon/public key
#   - SUPABASE_SERVICE_ROLE_KEY: Settings → API → service_role key (keep secret!)
#
# GROQ (https://console.groq.com)
#   - Sign up at console.groq.com
#   - GROQ_API_KEY: API Keys → Create API Key
#
# STRIPE (https://dashboard.stripe.com)
#   - STRIPE_SECRET_KEY: Developers → API keys → Secret key
#   - STRIPE_PUBLISHABLE_KEY / NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY: Developers → API keys → Publishable key
#   - STRIPE_WEBHOOK_SECRET: Developers → Webhooks → Add endpoint → Signing secret
#   - STRIPE_PRICE_ID: Products → (your product) → Pricing → Price ID
#
# RESEND (https://resend.com)
#   - RESEND_API_KEY: resend.com/api-keys → Create API Key
#   - RESEND_FROM_EMAIL: A verified sender address from your Resend domain
#
# UPSTASH REDIS (https://console.upstash.com)
#   - Create a Redis database at console.upstash.com
#   - UPSTASH_REDIS_REST_URL: Database details → REST URL
#   - UPSTASH_REDIS_REST_TOKEN: Database details → REST Token
#
# APP
#   - NEXT_PUBLIC_APP_URL: Your production domain (e.g. https://yourdomain.com)
#                          Use http://localhost:3000 for local development
# =============================================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Groq
GROQ_API_KEY=your-groq-api-key

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_ID=price_your-price-id

# Resend
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# App
NEXT_PUBLIC_APP_URL=https://yourdomain.com
